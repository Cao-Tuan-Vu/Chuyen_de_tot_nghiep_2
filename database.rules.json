{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        ".indexOn": ["email", "uid"]
      }
    },
    "profiles": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "sessions": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "courses": {
      ".read": "auth != null",
      ".write": false
    },
    "lessons": {
      ".read": "auth != null",
      ".write": false
    },
    "quizzes": {
      ".read": "auth != null",
      ".write": false
    },
    "attempts": {
      "$attemptId": {
        ".read": "auth != null && data.child('userId').val() == auth.uid",
        ".write": "auth != null && newData.child('userId').val() == auth.uid"
      }
    },
    "leaderboard": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "contacts": {
      "$messageId": {
        ".read": false,
        ".write": "auth != null"
      }
    },
    "notifications": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null",
        ".indexOn": ["timestamp"]
      }
    },
    ".read": false,
    ".write": false
  }
}